PROJECT_NAME=SOAR Platform
API_VERSION=0.1.0
API_V1_PREFIX=/api/v1
ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=INFO
BACKEND_CORS_ORIGINS=*
SECURITY_HEADERS_ENABLED=true
FORCE_HTTPS_HSTS=false

JWT_SECRET=change-me-in-production-min-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=soar
POSTGRES_USER=soar_user
POSTGRES_PASSWORD=soar_password
SQLALCHEMY_DATABASE_URI=postgresql+psycopg2://soar_user:soar_password@db:5432/soar

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB_BROKER=0
REDIS_DB_RESULT=1
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
CELERY_WORKER_CONCURRENCY=4
PLAYBOOK_QUEUE_CAPACITY=200
CELERY_TASK_MAX_RETRIES=3
CELERY_RETRY_BACKOFF_SECONDS=2
CELERY_QUEUE_DEFAULT=playbook_default
CELERY_QUEUE_EMAIL=playbook_email
CELERY_QUEUE_ENDPOINT=playbook_endpoint
CELERY_QUEUE_FILE=playbook_file

VIRUSTOTAL_API_KEY=<your_virustotal_api_key>
ABUSEIPDB_API_KEY=<your_abuseipdb_api_key>
ALIENVAULT_API_KEY=<your_alienvault_api_key>
MALWAREBAZAAR_API_KEY=<your_malwarebazaar_api_key>
SOAR_REPORTS_DIR=./reports
SOAR_DATASET_DIR=/app/app/soar/option1_datasets
THREAT_INTEL_TIMEOUT_SECONDS=10
THREAT_INTEL_MAX_RETRIES=1
THREAT_INTEL_RETRY_BACKOFF_SECONDS=0.5
