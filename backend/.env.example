PROJECT_NAME=SOAR Platform
API_VERSION=0.1.0
API_V1_PREFIX=/api/v1
ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=INFO
BACKEND_CORS_ORIGINS=*

POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=soar
POSTGRES_USER=soar_user
POSTGRES_PASSWORD=soar_password
SQLALCHEMY_DATABASE_URI=postgresql+psycopg2://soar_user:soar_password@db:5432/soar

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB_BROKER=0
REDIS_DB_RESULT=1
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
